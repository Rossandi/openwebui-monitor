# === OpenRouter API key ===
# Используется ОБОИМИ компонентами:
#   1. OpenWebUI шлёт запросы через Monitor-прокси с этим ключом
#   2. Monitor sync-воркер тем же ключом запрашивает GET /api/v1/generation?id=
OPENAI_API_KEY=sk-or-v1-your-openrouter-key

# === OpenWebUI ===
WEBUI_SECRET_KEY=change-me-to-a-random-string
OPEN_WEBUI_PORT=3000

# === Monitor ===
MONITOR_PORT=8088

# === PostgreSQL (для Monitor) ===
# Если пусто — используется дефолт "owmonitor". Сменить ОБЯЗАТЕЛЬНО на production.
POSTGRES_PASSWORD=owmonitor

# === Tavily (веб-поиск для LLM) ===
# Регистрация: https://app.tavily.com (бесплатно, 1000 запросов/мес)
TAVILY_API_KEY=

# === Генерация картинок (через прокси Monitor → OpenRouter) ===
# Альтернатива: google/gemini-2.5-flash-image
IMAGE_GENERATION_MODEL=openai/dall-e-3
IMAGE_SIZE=1024x1024

# === Jupyter Code Interpreter (опционально) ===
JUPYTER_TOKEN=
